  "keyFeatures": [
    "Complete MOQT protocol implementation with symmetric Publisher/Subscriber APIs",
    "Transport-agnostic design supporting HTTP/3 WebTransport and native QUIC",
    "Built-in relay and forwarding capabilities with namespace routing",
    "Object caching support for serving historical data to new subscribers",
    "Media streaming with MoqMi packaging and FLV format support",
    "Coroutine-based async APIs using Folly",
    "Flow control and backpressure management at multiple levels",
    "Comprehensive sample applications (date server, chat, media streaming)"
  ],
